// ─── State ────────────────────────────────────────────────────────────────────
let curIdx = 0, revealed = false, currentImgSrc = '', currentCase = null;

// ─── Streak + last-seen tracking ─────────────────────────────────────────────
let streak = 1;
const today = new Date().toDateString();
try {
  const sv = parseInt(localStorage.getItem('dl_s')||'1');
  const last = localStorage.getItem('dl_l');
  streak = (last && last !== today) ? (last===new Date(Date.now()-86400000).toDateString() ? sv+1 : 1) : sv;
  localStorage.setItem('dl_s', streak);
  localStorage.setItem('dl_l', today);
  curIdx = parseInt(localStorage.getItem('dl_idx')||'0');
} catch(e){}
document.getElementById('streakN').textContent = streak;
document.getElementById('metaDate').textContent = new Date().toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});

// ─── Daily reminder logic ─────────────────────────────────────────────────────
function checkReminder() {
  try {
    const lastOpened = localStorage.getItem('dl_opened');
    const installDismissed = localStorage.getItem('dl_install_dismissed');

    // Show "you haven't done today's case" banner if not opened today
    if (lastOpened !== today) {
      const banner = document.getElementById('reminderBanner');
      banner.classList.add('show');
      if (lastOpened) {
        const d = new Date(lastOpened);
        document.getElementById('reminderSub').textContent =
          `Last opened: ${d.toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short'})}`;
      } else {
        document.getElementById('reminderSub').textContent = 'Welcome — your first case awaits';
      }
    }

    // Show iOS install prompt if not installed and not dismissed
    const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
    const isStandalone = window.navigator.standalone;
    if (isIOS && !isStandalone && !installDismissed) {
      setTimeout(() => {
        document.getElementById('installBanner').classList.add('show');
      }, 2000);
    }
  } catch(e){}
}

function dismissBanner() {
  document.getElementById('reminderBanner').classList.remove('show');
  try { localStorage.setItem('dl_opened', today); } catch(e){}
}
function hideBanner() {
  document.getElementById('reminderBanner').classList.remove('show');
}
function hideInstall() {
  document.getElementById('installBanner').classList.remove('show');
  try { localStorage.setItem('dl_install_dismissed', '1'); } catch(e){}
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function rng(seed, n) { return (Math.sin(seed * 9301 + n * 49297 + 233995) * 0.5 + 0.5); }

function buildCase(idx) {
  const row = BANK[idx % BANK.length];
  const [id, code, age, sex, siteKey] = row;
  const d = DIAG[code];
  const isMal = ['mel','bcc','akiec'].includes(code);
  const hx = (isMal ? HX_MAL : HX_BEN)[Math.floor(rng(idx,2)*(isMal?HX_MAL:HX_BEN).length)];
  const hl = HEADLINES[code][idx % HEADLINES[code].length];
  const sf = STANDFIRSTS[code][Math.floor(idx/STANDFIRSTS[code].length) % STANDFIRSTS[code].length];
  return { isicId:id, code, diag:d, age:`${age}${sex}`, site:SITES[siteKey]||siteKey,
           duration:DURATION[Math.floor(rng(idx,1)*DURATION.length)], hx, headline:hl, standfirst:sf };
}

// ─── Image ───────────────────────────────────────────────────────────────────
function loadImage(id) {
  const urls = [
    `https://isic-archive.s3.amazonaws.com/images/${id}.jpg`,
    `https://isic-archive.s3.amazonaws.com/images/${id}_resized.jpg`,
  ];
  let i = 0;
  document.getElementById('errLnk').href = `https://api.isic-archive.com/images/${id}/`;
  document.getElementById('isicLnk').href = `https://api.isic-archive.com/images/${id}/`;
  document.getElementById('isicLnk').textContent = `${id} ↗`;
  function tryNext() {
    if (i >= urls.length) {
      document.getElementById('imgLoader').classList.add('gone');
      document.getElementById('imgErr').classList.add('show'); return;
    }
    const img = new Image();
    img.onload = () => {
      currentImgSrc = urls[i];
      document.getElementById('imgLoader').classList.add('gone');
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.6s ease;filter:contrast(1.05) saturate(1.08);';
      document.getElementById('imgFrame').appendChild(img);
    };
    img.onerror = () => { i++; tryNext(); };
    img.src = urls[i++];
  }
  tryNext();
}

function openZoom() { if(!currentImgSrc) return; document.getElementById('zoomImg').src=currentImgSrc; document.getElementById('zoomModal').classList.add('open'); }
function closeZoom() { document.getElementById('zoomModal').classList.remove('open'); }
document.addEventListener('keydown', e => { if(e.key==='Escape') closeZoom(); });

// ─── Render ───────────────────────────────────────────────────────────────────
function renderCase(idx) {
  revealed = false; currentImgSrc = '';
  const c = buildCase(idx);
  currentCase = c;
  try { localStorage.setItem('dl_idx', idx); } catch(e){}

  document.getElementById('caseNum').textContent = (idx % BANK.length) + 1;
  document.getElementById('kicker').textContent = c.diag.kicker;
  document.getElementById('headline').textContent = c.headline;
  document.getElementById('standfirst').textContent = c.standfirst;
  document.getElementById('cAge').textContent = c.age;
  document.getElementById('cSite').textContent = c.site;
  document.getElementById('cDuration').textContent = c.duration;
  document.getElementById('cHx').textContent = c.hx;
  document.getElementById('dxVal').textContent = c.diag.name;
  document.getElementById('imgAttrib').textContent = `${c.isicId} · HAM10000 · CC-BY-NC`;

  document.getElementById('locked').style.display = 'block';
  const ng = document.getElementById('nuggetsGrid');
  ng.classList.remove('show'); ng.innerHTML = '';
  document.getElementById('revealBtn').classList.remove('gone');
  document.getElementById('btm').classList.remove('show');

  const frame = document.getElementById('imgFrame');
  const old = frame.querySelector('img'); if(old) old.remove();
  document.getElementById('imgLoader').classList.remove('gone');
  document.getElementById('imgErr').classList.remove('show');
  currentImgSrc = '';
  loadImage(c.isicId);
}

// ─── AI Nuggets ───────────────────────────────────────────────────────────────
async function fetchNuggets(c) {
  const prompt = `You are a senior dermatologist writing a daily dermoscopy learning card for a practicing clinician.

Diagnosis: ${c.diag.name}
ISIC Image ID: ${c.isicId}

Write exactly 6 bite-sized learning nuggets. Each is clinically precise and memorable. Return ONLY a valid JSON array of 6 objects, no markdown:
[
  {"icon":"🔴","dark":true,"title":"The Clincher","text":"The single most pathognomonic feature with <strong>key term bolded</strong>."},
  {"icon":"🔵","dark":false,"title":"Supporting Feature","text":"Second key dermoscopic feature..."},
  {"icon":"⚠️","dark":false,"title":"Pitfall to Avoid","text":"The most dangerous specific diagnostic error..."},
  {"icon":"📐","dark":false,"title":"Pattern Rule","text":"A memorable rule or mnemonic..."},
  {"icon":"🧠","dark":false,"title":"Clinical Pearl","text":"Management or clinical context..."},
  {"icon":"🎯","dark":false,"title":"Take Home","text":"One memorable fact..."}
]
Rules: Use <strong> for key terms. Max 2 sentences each. First nugget always dark:true. Be specific not generic.`;

  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST", headers:{"Content-Type":"application/json"},
      body: JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:1000, messages:[{role:"user",content:prompt}] })
    });
    const data = await res.json();
    const raw = data.content?.map(b=>b.text||'').join('').trim()||'';
    return JSON.parse(raw.replace(/```json|```/g,'').trim());
  } catch(e) { return fallback(c.code); }
}

function fallback(code) {
  const F = {
    mel:[{icon:"🔴",dark:true,title:"The Clincher",text:"<strong>Atypical pigment network</strong> — irregular meshwork with variable line thickness and abrupt border termination is melanoma's most important single feature."},{icon:"🔵",dark:false,title:"Regression Structures",text:"<strong>Blue-grey peppering</strong> within a white scar-like zone signals tumour regression — a worrying prognostic sign when asymmetrically placed."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"Do not dismiss because it lacks blue-black colour. <strong>Hypomelanotic melanoma</strong> fools even experienced dermoscopists — look for structural asymmetry."},{icon:"📐",dark:false,title:"3-Colour Rule",text:"Three or more distinct colours in one lesion has high specificity for melanoma. Apply the <strong>3-colour rule</strong> as a rapid screening step."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"The <strong>multicomponent pattern</strong> (≥3 structural zones) drives the decision to excise — when in doubt, the lesion comes off."},{icon:"🎯",dark:false,title:"Take Home",text:"<strong>Pseudopods and streaks</strong> at the border represent confluent melanocyte nests pushing outward — always indicate excision."}],
    nv:[{icon:"🟤",dark:true,title:"The Clincher",text:"<strong>Regular pigment network</strong> with uniform line thickness, consistent hole size, and symmetric peripheral fading is the benign naevus signature."},{icon:"📏",dark:false,title:"Symmetry",text:"Mentally fold on both axes — a benign naevus shows <strong>structural and colour symmetry</strong> on both planes."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"Normal-appearing network on <strong>special sites</strong> (palms, soles, genitalia) needs different criteria — benign-looking palmar network may be melanoma in situ."},{icon:"📅",dark:false,title:"Follow-up Rule",text:"Stable naevi with typical pattern in patients under 40 need <strong>no routine follow-up</strong>. Photography reserved for high-risk patients only."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"The <strong>ugly duckling sign</strong> outperforms individual lesion analysis — any lesion unlike the patient's others demands scrutiny."},{icon:"🎯",dark:false,title:"Take Home",text:"Network <strong>fading at the periphery</strong> is benign. Network thickening toward the edge is the inverse — and should prompt concern."}],
    bcc:[{icon:"🌳",dark:true,title:"The Clincher",text:"<strong>Arborising telangiectasia</strong> — large-calibre branching vessels, tree-like structure, sharp focus under polarised light — is highly specific for BCC."},{icon:"🔵",dark:false,title:"Blue-Grey Nests",text:"<strong>Ovoid blue-grey nests</strong> are large, well-demarcated structures representing pigmented tumour islands — they confirm BCC even without vessels."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"<strong>Morphoeic BCC</strong> may show only white structureless areas with sparse vessels — on the face, unexplained white with subtle vessels warrants biopsy."},{icon:"✨",dark:false,title:"Polarised Secret",text:"<strong>Chrysalis structures</strong> (shiny white lines, only under polarised light) represent fibrous stroma — highly specific for BCC and thick melanoma."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"BCC essentially <strong>never metastasises</strong>, but facial lesions cause devastating local destruction. Timely diagnosis prevents complex reconstruction."},{icon:"🎯",dark:false,title:"Take Home",text:"Superficial BCC shows <strong>multiple small erosions</strong> and fine vessels rather than arborising telangiectasia — subtype recognition changes treatment."}],
    akiec:[{icon:"🌀",dark:true,title:"The Clincher",text:"<strong>Coiled (glomerular) vessels</strong> — tightly wound capillaries in clusters on erythematous background — are the most specific feature of Bowen's disease."},{icon:"🍓",dark:false,title:"AK Pattern",text:"Actinic keratosis shows the <strong>strawberry pattern</strong>: pink-red pseudo-network with white follicular openings surrounded by red halos."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"<strong>Irritated or inflamed AK</strong> can mimic psoriasis clinically. Dermoscopy — specifically the vessel pattern — reliably differentiates them."},{icon:"📐",dark:false,title:"Invasion Sign",text:"White structureless areas within a Bowen's lesion signal <strong>invasion into SCC</strong> — their presence changes management from topical to surgical."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"On the <strong>face of elderly patients</strong>, the AK field may extend beyond visible borders — treat the field, not just the lesion."},{icon:"🎯",dark:false,title:"Take Home",text:"<strong>Bowen's disease of the nail unit</strong> is often mistaken for periungual wart — periungual HPV-related SCC is an important diagnostic trap."}],
    bkl:[{icon:"⬛",dark:true,title:"The Clincher",text:"<strong>Comedo-like openings</strong> (sharply demarcated crypts) combined with <strong>milia-like cysts</strong> (white-yellow globules) are pathognomonic for seborrhoeic keratosis."},{icon:"🧠",dark:false,title:"Cerebriform Pattern",text:"The <strong>gyrus-and-sulcus pattern</strong> — resembling a brain surface — is seen in heavily pigmented SK and is one of dermoscopy's most distinctive patterns."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"<strong>Irritated SK</strong> destroys the typical pattern — inflammation introduces vessels and regression-like structures, making biopsy mandatory."},{icon:"🌞",dark:false,title:"Solar Lentigo",text:"<strong>Solar lentigo</strong> shows a moth-eaten border pattern with sharp demarcation — a distinct entity within the BKL category, common on sun-exposed sites."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"<strong>LPLK</strong> is an involuting SK that shows regression features mimicking melanoma — single lesion in an elderly patient is the clinical context clue."},{icon:"🎯",dark:false,title:"Take Home",text:"SK can occur within a naevus as a <strong>collision lesion</strong> — if you see SK features in one zone and naevus in another, that is the explanation."}],
    df:[{icon:"⬜",dark:true,title:"The Clincher",text:"<strong>Central white scar-like patch</strong> surrounded by a delicate peripheral pigment network is pathognomonic for dermatofibroma — no other diagnosis produces this combination."},{icon:"👆",dark:false,title:"Dimple Sign",text:"Lateral compression produces a <strong>central dimple</strong> — unique to dermatofibroma, reflecting fibrous tethering to the deep dermis."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"<strong>Cellular dermatofibroma</strong> shows atypical features including irregular vessels — if the classic pattern is absent, biopsy rather than reassure."},{icon:"💡",dark:false,title:"Polarised Insight",text:"The central white area shows <strong>bright shiny structures</strong> under polarised light — representing dense collagen, not regression as in melanoma."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"Dermatofibroma is the most <strong>commonly biopsied benign lesion</strong> in practice — mastering its pattern spares patients unnecessary procedures."},{icon:"🎯",dark:false,title:"Take Home",text:"<strong>Haemosiderotic DF</strong> adds brown globules to the classic pattern; <strong>atrophic DF</strong> may lack the peripheral network — but the dimple sign persists."}],
    vasc:[{icon:"🔴",dark:true,title:"The Clincher",text:"<strong>Red lacunae</strong> — well-circumscribed, round-to-oval red to red-blue areas separated by whitish septa — are pathognomonic for haemangioma."},{icon:"🟣",dark:false,title:"Colour Spectrum",text:"Lacunae range from <strong>bright red (superficial) to dark violet or black</strong> (thrombosed) — darker means older, not necessarily more dangerous."},{icon:"⚠️",dark:false,title:"Pitfall to Avoid",text:"<strong>Thrombosed haemangioma</strong> can mimic melanoma — dark structureless areas with no visible lacunae. Biopsy if uncertain rather than reassure."},{icon:"🩸",dark:false,title:"Angiokeratoma",text:"<strong>Angiokeratoma</strong> shows lacunae plus a dark veil and scaly surface — distinguishable from haemangioma by its surface hyperkeratosis."},{icon:"🧠",dark:false,title:"Clinical Pearl",text:"<strong>Pyogenic granuloma</strong> shows white rail lines surrounding red lobular vascular areas — a distinct vascular pattern that clinches the diagnosis."},{icon:"🎯",dark:false,title:"Take Home",text:"The <strong>red lacunar pattern</strong> is so specific for benign vascular lesions that seeing it should immediately trigger reassurance rather than concern."}],
  };
  return F[code]||F.nv;
}

// ─── Reveal ───────────────────────────────────────────────────────────────────
async function reveal() {
  if (revealed) return;
  revealed = true;
  // Mark today as opened
  try { localStorage.setItem('dl_opened', today); } catch(e){}
  dismissBanner();

  document.getElementById('revealBtn').classList.add('gone');
  document.getElementById('locked').style.display = 'none';
  const ng = document.getElementById('nuggetsGrid');
  ng.innerHTML = Array(6).fill(`<div class="skel-n"><div class="sk s"></div><div class="sk m"></div><div class="sk l"></div><div class="sk m"></div></div>`).join('');
  ng.classList.add('show');

  const nuggets = await fetchNuggets(currentCase);
  ng.innerHTML = nuggets.map((n,i)=>`
    <div class="nugget ${n.dark?'dark':''}" data-n="${i+1}" style="animation-delay:${i*0.07}s">
      <span class="n-ico">${n.icon}</span>
      <div class="n-ttl">${n.title}</div>
      <div class="n-txt">${n.text}</div>
    </div>`).join('');

  document.getElementById('btm').classList.add('show');
  ng.scrollIntoView({behavior:'smooth',block:'nearest'});
}

function nextCase() { curIdx++; window.scrollTo({top:0,behavior:'smooth'}); setTimeout(()=>renderCase(curIdx),180); }
function prevCase() { if(curIdx<=0)return; curIdx--; window.scrollTo({top:0,behavior:'smooth'}); setTimeout(()=>renderCase(curIdx),180); }

// ─── Service Worker ───────────────────────────────────────────────────────────
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./sw.js').then(reg => {
      console.log('SW registered:', reg.scope);
    }).catch(err => console.log('SW failed:', err));
  });
}

// ─── Init ─────────────────────────────────────────────────────────────────────
const dayOfYear = Math.floor((new Date()-new Date(new Date().getFullYear(),0,0))/86400000);
if (curIdx === 0) curIdx = dayOfYear % BANK.length;

checkReminder();
renderCase(curIdx);
</script>
</body>
</html>
